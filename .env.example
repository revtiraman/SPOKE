# ============================================================
# SPOKE — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# ── HuggingFace (Required for full pipeline) ──────────────
HF_API_TOKEN=hf_your_token_here

# ── Model Selection (defaults are optimal for cost/quality) ─
MAIN_BRAIN_MODEL=moonshotai/Kimi-K2-Instruct
PLANNER_MODEL=deepseek-ai/DeepSeek-R1
CODER_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
FAST_MODEL=meta-llama/Llama-3.3-70B-Instruct
TINY_MODEL=Qwen/Qwen3-4B

# ── Anthropic (Optional premium brain) ───────────────────
ANTHROPIC_API_KEY=

# ── Sandbox Execution ─────────────────────────────────────
# Options: subprocess | e2b | docker
SANDBOX_TYPE=subprocess
E2B_API_KEY=

# ── GitHub (Optional — auto-creates repo on deploy) ───────
GITHUB_TOKEN=

# ── Pipeline Tuning ───────────────────────────────────────
MAX_DEBUG_RETRIES=5
EXECUTION_TIMEOUT_SECONDS=120
MAX_VIDEO_DURATION_SECONDS=180
LOG_LEVEL=INFO

# ── App Settings ──────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_PORT=8501

# ── Demo Mode (set to true to skip all API calls) ─────────
DEMO_MODE=false
